rules_version = '2';

// Anaj Bahi — Firestore Security Rules
//
// PHASE 6–7 (interim): any SIGNED-IN user may read/write. This is enough for the
// auth + business spine and the shared-ledger data layer while there is a single
// trader (and their own employees) using their own project. It is NOT wide open —
// unauthenticated requests are denied.
//
// PHASE 8–9 (planned) tightens this to the frozen model in
// spec/architecture.md § "Firestore data model — frozen collection-path map":
//   - users/{uid}                      → only the owner (uid == request.auth.uid)
//   - memberships/{phoneKey}           → the phone owner or a member of bizId; writes by an owner of bizId
//   - businesses/{bizId}               → read: any member; write: an owner
//   - businesses/{bizId}/bills|farmers|grainTypes → read/write: any member of bizId
//   - businesses/{bizId}/activity      → read: OWNERS only; create-only for members; no update/delete
// Do not ship Phase 8 without replacing the block below with those per-role rules.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
