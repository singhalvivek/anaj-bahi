rules_version = '2';

// Anaj Bahi — Firestore Security Rules
//
// PHASE 8 (role boundaries) + PHASE 9 (finalized/hardened). Phase 8 replaced the
// earlier interim "any signed-in user" rules with real per-role boundaries; Phase 9
// FINALIZES them — the activity path is append-only (create-only, no update/delete)
// with OWNER-only reads, and all other boundaries below are the confirmed final pass.
// Drawn from the frozen model in
// spec/architecture.md § "Firestore data model — frozen collection-path map":
//   - users/{uid}                      → only the owner (uid == request.auth.uid)
//   - invites/{code}                   → read: any signed-in user (an employee reads
//                                         the invite to verify code+mobile before they
//                                         are a member); create/update: an owner of the
//                                         invite's bizId OR the claimer stamping their
//                                         own uid; delete: an owner of the business
//   - businesses/{bizId}               → read: any member; write: an owner
//   - businesses/{bizId}/members/{uid} → read: any member; create: self ONLY via the
//                                         owner-bootstrap arm (role owner + business not
//                                         yet existing) or the employee-claim arm (a
//                                         matching UNUSED invites/{inviteCode} tying
//                                         bizId + phoneKey), OR an owner; update: owner
//                                         or self; delete: owner
//   - businesses/{bizId}/bills|farmers|grainTypes → read/write: any member of bizId
//   - businesses/{bizId}/activity      → read: OWNERS only; create-only for members;
//                                         no update/delete (Phase 9 — final append-only)
//
// These rules are claim-bootstrap-safe: verified against the onboarding writeBatch
// in lib/tenancy/business.ts (createBusiness) and lib/tenancy/invite.ts (claimInvite)
// — the owner and employee self-create their own member docs before any membership
// exists to check, so members create allows `request.auth.uid == uid`, and the invite
// claim update allows `claimedByUid == request.auth.uid`.
//
// NOTE: the activity match block below is UNCHANGED from Phase 8 (it was already the
// hardened target: create-only for members, owner-only read, update/delete forbidden).
// Phase 9 slice-a only updated these COMMENTS — the enforced rules are byte-identical,
// so NO re-publish is required for this change. (These rules must, of course, have been
// PUBLISHED once — via the Firebase console or `firebase deploy --only firestore:rules`
// — for the app and the slice-c role E2E (activity-log.spec.ts) to enforce them.)

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }
    function memberDoc(bizId) { return /databases/$(database)/documents/businesses/$(bizId)/members/$(request.auth.uid); }
    function isMember(bizId) { return signedIn() && exists(memberDoc(bizId)); }
    function isOwner(bizId) { return isMember(bizId) && get(memberDoc(bizId)).data.role == 'owner'; }

    match /users/{uid} {
      allow read, write: if isSelf(uid);
    }

    // Owner-generated one-time employee invites (invites/{code}). GET is by-id (the
    // code is a shared secret an employee reads pre-membership); LIST is owner-only,
    // so no one can enumerate another business's invites. Only an owner mints/cancels;
    // the sole non-owner write is the single-use unused→claimed transition, stamped
    // with the claimer's own uid.
    match /invites/{code} {
      allow get:    if signedIn();
      allow list:   if signedIn() && isOwner(resource.data.bizId);
      allow create: if signedIn() && isOwner(request.resource.data.bizId);
      allow update: if signedIn() && (
        isOwner(resource.data.bizId) ||
        ( resource.data.status == 'unused'
          && request.resource.data.status == 'claimed'
          && request.resource.data.claimedByUid == request.auth.uid )
      );
      allow delete: if signedIn() && isOwner(resource.data.bizId);
    }

    match /businesses/{bizId} {
      allow read: if isMember(bizId);
      allow create: if signedIn() && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isOwner(bizId);
      allow delete: if false;

      match /members/{uid} {
        allow read: if isMember(bizId);
        // Self-create is tightly gated to two legitimate bootstraps, else an owner
        // writes roster docs. Rules see only COMMITTED state during a client batch,
        // so the owner-bootstrap arm reads businesses/{bizId} as still-absent, and the
        // employee-claim arm reads the invite as still-'unused'.
        allow create: if signedIn() && request.auth.uid == uid && (
          // owner bootstrap — ONLY while the business does not yet exist (create batch),
          // which blocks self-owning an already-existing business:
          ( request.resource.data.role == 'owner'
            && !exists(/databases/$(database)/documents/businesses/$(bizId)) )
          ||
          // employee claim — gated on a REAL matching UNUSED invite (by code), tying
          // bizId + phoneKey:
          ( request.resource.data.role == 'employee'
            && exists(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode))
            && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.bizId == bizId
            && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.phoneKey == request.resource.data.phoneKey
            && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.status == 'unused' )
        ) || isOwner(bizId);
        allow update: if isOwner(bizId) || isSelf(uid);
        allow delete: if isOwner(bizId);
      }
      match /bills/{billId}      { allow read, write: if isMember(bizId); }
      match /farmers/{farmerId}  { allow read, write: if isMember(bizId); }
      match /grainTypes/{gtId}   { allow read, write: if isMember(bizId); }
      match /activity/{activityId} {
        allow read: if isOwner(bizId);
        allow create: if isMember(bizId);
        allow update, delete: if false;
      }
    }
  }
}
