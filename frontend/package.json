{
  "name": "agent-frontend",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pages": "node scripts/gen-version.mjs && next build && node scripts/stamp-sw.mjs && node scripts/apply-base-path.mjs",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --only firestore --project demo-anaj-bahi --config ../firebase.json \"vitest run --config vitest.rules.config.ts\"",
    "test:e2e": "firebase emulators:exec --only auth,firestore --project demo-anaj-bahi --config ../firebase.json \"playwright test\"",
    "test:e2e:only": "playwright test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dexie": "^4",
    "dexie-react-hooks": "^1",
    "firebase": "^11",
    "html-to-image": "^1",
    "next": "15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3",
    "@playwright/test": "^1.6",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "fake-indexeddb": "^6",
    "firebase-admin": "^13",
    "firebase-tools": "^13",
    "jsdom": "^25",
    "tailwindcss": "^4.1.8",
    "typescript": "^5",
    "vitest": "^2"
  }
}
