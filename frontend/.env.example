# ---------------------------------------------------------------------------
# Anaj Bahi — Firebase config (Phase 6+). Copy to `.env.local` and fill in.
# `.env.local` is gitignored; NEVER commit it.
#
# The 6 NEXT_PUBLIC_FIREBASE_* values are PUBLIC Firebase Web config (safe to
# ship in the client bundle) — real security is enforced by Firestore Rules.
# Get them from: Firebase Console -> Project settings -> Your apps -> Web app -> SDK config.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# Emulator toggle (E2E / optional local dev). When 'true' (or '1'), the app
# points Auth + Firestore at the local Firebase emulators (Auth 9099, Firestore
# 8080 — see firebase.json). Google sign-in is then simulated by the Auth
# emulator's built-in test-IdP popup (no real Google account, no network).
# Default (unset / 'false') -> real Firebase. Playwright sets this to '1'.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_USE_EMULATORS=false

# ---------------------------------------------------------------------------
# Auth is Google sign-in (GoogleAuthProvider + signInWithPopup), free on the
# Spark plan. There is NO phone/SMS/OTP and NO reCAPTCHA. There is NO service
# account and NO FIREBASE_SERVICE_ACCOUNT secret: E2E runs against the emulators
# and the Firestore emulator is reset via its REST endpoint, so firebase-admin
# is not required.
#
# Console prerequisites (real project only, out-of-band — see DEPLOY.md):
#   - Authentication -> Sign-in method -> enable Google (with a support email)
#   - Authentication -> Settings -> Authorized domains -> add your Pages host
# ---------------------------------------------------------------------------
