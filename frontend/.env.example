# ---------------------------------------------------------------------------
# Anaj Bahi — Firebase config (Phase 6+). Copy to `.env.local` and fill in.
# `.env.local` is gitignored; NEVER commit it.
#
# The 6 NEXT_PUBLIC_FIREBASE_* values are PUBLIC Firebase Web config (safe to
# ship in the client bundle) — real security is enforced by Firestore Rules.
# Get them from: Firebase Console -> Project settings -> Your apps -> Web app -> SDK config.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# E2E-only. The ONE real secret. Path to a Firebase service-account JSON key,
# used ONLY by the Playwright global-setup (Firebase Admin SDK) to reset the
# test user's Firestore docs before each run. No NEXT_PUBLIC_ prefix => never
# inlined into the client bundle. Leave blank if not running E2E.
# ---------------------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT=

# ---------------------------------------------------------------------------
# Canonical E2E test phone number (add this exact pair in the Firebase Console:
# Authentication -> Sign-in method -> Phone -> Phone numbers for testing):
#   Phone: +911111111111    OTP: 123456
# Sends no real SMS, bypasses reCAPTCHA -> deterministic E2E, no SMS quota used.
# ---------------------------------------------------------------------------
